PROGRAM ESTEIRA

VAR_EXTERNAL
	ESTEIRA :BOOL; //SD1
	VALVULA :BOOL; //SD2
	S_GARR  :BOOL; //ED1
	CNTER   :UDINT;//VAR CONTAGEM
END_VAR

MAQUINA LINHA_GARRAFAS:
ESTADO 0:
	LIGA ESTEIRA;
	SE S_GARR = 1 ENTAO 1;
ESTADO 1:
	DESL ESTEIRA;
	LIGA VALVULA;
	SE ATRASO = T#1s ENTAO 2;
ESTADO 2:
	DESL VALVULA;
	INCREMENTA CNTER;
	VA PARA 0;

END_PROGRAM